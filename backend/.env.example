# Server
SERVER_PORT=8080

# Supabase PostgreSQL (keep password URL-encoded if embedded in URL)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xlmkbtschuljiujxqwic.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<SUPABASE_DB_PASSWORD>

# Secrets source override (optional)
FOODYA_SECRETS_JSON_FILE=config/api-keys.json

# Integrations
GOOGLE_AI_STUDIO_API_KEY=<GOOGLE_AI_STUDIO_KEY>
SUPABASE_PROJECT_URL=https://<your-project-id>.supabase.co
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=<SUPABASE_S3_ACCESS_KEY_ID>
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=<SUPABASE_S3_SECRET_ACCESS_KEY>
GOONG_API_KEY=<GOONG_API_KEY>
OPENWEATHER_API_KEY=<OPENWEATHER_API_KEY>

# Firebase (web config values)
FIREBASE_API_KEY=<FIREBASE_API_KEY>
FIREBASE_AUTH_DOMAIN=<FIREBASE_AUTH_DOMAIN>
